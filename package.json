{
  "name": "curso.dev",
  "version": "1.0.0",
  "description": "A Tabnews clone",
  "main": "index.js",
  "dependencies": {
    "async-retry": "^1.3.3",
    "dotenv-expand": "^11.0.6",
    "next": "^16.1.6",
    "node-pg-migrate": "^6.2.2",
    "pg": "^8.11.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "jest": "^29.6.2",
    "prettier": "^3.8.1"
  },
  "scripts": {
    "dev2": "concurrently --names migrations,next -k \"npm run migrations:up\" \"next dev\"",
    "dev": "npm run migrations:up && next dev",
    "lint:check": "prettier --check .",
    "lint:fix": "prettier --write .",
    "test": "concurrently --names next,jest -k --success command-jest \"next dev\" \"sleep 10 && jest --passWithNoTests --runInBand --verbose\"",
    "test:watch": "jest --watchAll --passWithNoTests --runInBand",
    "migrations:create": "node-pg-migrate create create-users-table -m infra/migrations",
    "migrations:up": "node-pg-migrate up -m infra/migrations --envPath .env.development",
    "migrations:down": "node-pg-migrate down -m infra/migrations --envPath .env.development",
    "wait-for-postgres": "node infra/scripts/wait-for-postgres.js && concurrently --names next,jest -k \"next dev\" \"jest --runInBand --watchAll --verbose\""
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/gariani/clone_tabnews.git"
  },
  "author": "Daniel Gariani Rafael",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/gariani/clone_tabnews/issues"
  },
  "homepage": "https://github.com/gariani/clone_tabnews#readme"
}
